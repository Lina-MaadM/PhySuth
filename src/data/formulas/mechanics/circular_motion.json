{
  "topic": "Mechanics",
  "subtopic": "Circular Motion",
  "description": "Uniform circular motion: relationship between linear and angular quantities, centripetal acceleration, and force.",
  "variable_sub": [
    {
      "key": "PI_Mechanics",
      "symbol": "\\pi",
      "name": "Pi",
      "unit": "",
      "value": 3.141592,
      "isFixed": true,
      "description": "Mathematical constant Pi (Fixed)"
    },
    {
      "key": "v_Mechanics",
      "symbol": "v",
      "name": "Linear Velocity",
      "unit": "m/s",
      "description": "The speed or velocity of an object along the arc."
    },
    {
      "key": "omega_Mechanics",
      "symbol": "\\omega",
      "name": "Angular Velocity",
      "unit": "rad/s",
      "description": "Rate of rotation (can be negative for direction)."
    },
    {
      "key": "r_Mechanics",
      "symbol": "r",
      "name": "Radius",
      "unit": "m",
      "min": 0.000001,
      "description": "Radius of the circular path."
    },
    {
      "key": "T_Mechanics",
      "symbol": "T",
      "name": "Period",
      "unit": "s",
      "min": 0.000001,
      "description": "Time for one complete revolution."
    },
    {
      "key": "f_Mechanics",
      "symbol": "f",
      "name": "Frequency",
      "unit": "Hz",
      "min": 0,
      "description": "Revolutions per second (1/T)."
    },
    {
      "key": "ac_Mechanics",
      "symbol": "a_c",
      "name": "Centripetal Acceleration",
      "unit": "m/s^2",
      "description": "Acceleration pointing toward the center."
    },
    {
      "key": "Fc_Mechanics",
      "symbol": "F_c",
      "name": "Centripetal Force",
      "unit": "N",
      "description": "Force required to maintain circular motion."
    },
    {
      "key": "m_Mechanics",
      "symbol": "m",
      "name": "Mass",
      "unit": "kg",
      "min": 0.000001,
      "description": "Mass of the moving object."
    }
  ],
  "formula_sub": [
    {
      "id": "circ-1",
      "name": "Linear and Angular Relationship",
      "formula": "v = \\omega r",
      "variable": [
        "v_Mechanics",
        "omega_Mechanics",
        "r_Mechanics"
      ],
      "calculate": {
        "v_Mechanics": { "type": "expression", "value": "omega_Mechanics * r_Mechanics" },
        "omega_Mechanics": { "type": "expression", "value": "v_Mechanics / r_Mechanics" },
        "r_Mechanics": { "type": "expression", "value": "v_Mechanics / omega_Mechanics" }
      }
    },
    {
      "id": "circ-2",
      "name": "Angular Velocity (Period)",
      "formula": "\\omega = 2\\pi / T",
      "variable": [
        "omega_Mechanics",
        "T_Mechanics",
        "PI_Mechanics"
      ],
      "calculate": {
        "omega_Mechanics": { "type": "expression", "value": "2 * PI_Mechanics / T_Mechanics" },
        "T_Mechanics": { "type": "expression", "value": "2 * PI_Mechanics / omega_Mechanics" }
      }
    },
    {
      "id": "circ-3",
      "name": "Angular Velocity (Frequency)",
      "formula": "\\omega = 2\\pi f",
      "variable": [
        "omega_Mechanics",
        "f_Mechanics",
        "PI_Mechanics"
      ],
      "calculate": {
        "omega_Mechanics": { "type": "expression", "value": "2 * PI_Mechanics * f_Mechanics" },
        "f_Mechanics": { "type": "expression", "value": "omega_Mechanics / (2 * PI_Mechanics)" }
      }
    },
    {
      "id": "circ-4",
      "name": "Centripetal Acceleration (Linear)",
      "formula": "a_c = v^2 / r",
      "variable": [
        "ac_Mechanics",
        "v_Mechanics",
        "r_Mechanics"
      ],
      "calculate": {
        "ac_Mechanics": { "type": "expression", "value": "pow(v_Mechanics, 2) / r_Mechanics" },
        "v_Mechanics": { "type": "expression", "value": "sqrt(ac_Mechanics * r_Mechanics)" },
        "r_Mechanics": { "type": "expression", "value": "pow(v_Mechanics, 2) / ac_Mechanics" }
      }
    },
    {
      "id": "circ-5",
      "name": "Centripetal Acceleration (Angular)",
      "formula": "a_c = \\omega^2 r",
      "variable": [
        "ac_Mechanics",
        "omega_Mechanics",
        "r_Mechanics"
      ],
      "calculate": {
        "ac_Mechanics": { "type": "expression", "value": "pow(omega_Mechanics, 2) * r_Mechanics" },
        "omega_Mechanics": { "type": "expression", "value": "sqrt(ac_Mechanics / r_Mechanics)" },
        "r_Mechanics": { "type": "expression", "value": "ac_Mechanics / pow(omega_Mechanics, 2)" }
      }
    },
    {
      "id": "circ-6",
      "name": "Centripetal Force",
      "formula": "F_c = m a_c",
      "variable": [
        "Fc_Mechanics",
        "m_Mechanics",
        "ac_Mechanics"
      ],
      "calculate": {
        "Fc_Mechanics": { "type": "expression", "value": "m_Mechanics * ac_Mechanics" },
        "m_Mechanics": { "type": "expression", "value": "Fc_Mechanics / ac_Mechanics" },
        "ac_Mechanics": { "type": "expression", "value": "Fc_Mechanics / m_Mechanics" }
      }
    }
  ]
}