{
  "topic": "Mechanics",
  "subtopic": "Circular Motion",
  "description": "Uniform circular motion and the relationships between linear and angular quantities, centripetal acceleration, and centripetal force.",
  "formula_sub": [
    {
      "id": "circ-1",
      "name": "Linear and Angular Relationship",
      "formula": "v = \\omega r",
      "variable": [
        "v_Mechanics",
        "omega_Mechanics",
        "r_Mechanics"
      ],
      "calculate": {
        "v_Mechanics": {
          "type": "expression",
          "value": "omega_Mechanics * r_Mechanics"
        },
        "omega_Mechanics": {
          "type": "expression",
          "value": "v_Mechanics / r_Mechanics"
        },
        "r_Mechanics": {
          "type": "expression",
          "value": "v_Mechanics / omega_Mechanics"
        }
      }
    },
    {
      "id": "circ-2",
      "name": "Angular Velocity (Period)",
      "formula": "\\omega = 2\\pi / T",
      "variable": [
        "omega_Mechanics",
        "T_Mechanics",
        "PI_Mechanics"
      ],
      "calculate": {
        "omega_Mechanics": {
          "type": "expression",
          "value": "2 * PI_Mechanics / T_Mechanics"
        },
        "T_Mechanics": {
          "type": "expression",
          "value": "2 * PI_Mechanics / omega_Mechanics"
        }
      }
    },
    {
      "id": "circ-3",
      "name": "Angular Velocity (Frequency)",
      "formula": "\\omega = 2\\pi f",
      "variable": [
        "omega_Mechanics",
        "f_Mechanics",
        "PI_Mechanics"
      ],
      "calculate": {
        "omega_Mechanics": {
          "type": "expression",
          "value": "2 * PI_Mechanics * f_Mechanics"
        },
        "f_Mechanics": {
          "type": "expression",
          "value": "omega_Mechanics / (2 * PI_Mechanics)"
        }
      }
    },
    {
      "id": "circ-4",
      "name": "Centripetal Acceleration (Linear)",
      "formula": "a_c = v^2 / r",
      "variable": [
        "ac_Mechanics",
        "v_Mechanics",
        "r_Mechanics"
      ],
      "calculate": {
        "ac_Mechanics": {
          "type": "expression",
          "value": "pow(v_Mechanics, 2) / r_Mechanics"
        },
        "v_Mechanics": {
          "type": "expression",
          "value": "sqrt(ac_Mechanics * r_Mechanics)"
        },
        "r_Mechanics": {
          "type": "expression",
          "value": "pow(v_Mechanics, 2) / ac_Mechanics"
        }
      }
    },
    {
      "id": "circ-5",
      "name": "Centripetal Acceleration (Angular)",
      "formula": "a_c = \\omega^2 r",
      "variable": [
        "ac_Mechanics",
        "omega_Mechanics",
        "r_Mechanics"
      ],
      "calculate": {
        "ac_Mechanics": {
          "type": "expression",
          "value": "pow(omega_Mechanics, 2) * r_Mechanics"
        },
        "omega_Mechanics": {
          "type": "expression",
          "value": "sqrt(ac_Mechanics / r_Mechanics)"
        },
        "r_Mechanics": {
          "type": "expression",
          "value": "ac_Mechanics / pow(omega_Mechanics, 2)"
        }
      }
    },
    {
      "id": "circ-6",
      "name": "Centripetal Force",
      "formula": "F_c = m a_c",
      "variable": [
        "Fc_Mechanics",
        "m_Mechanics",
        "ac_Mechanics"
      ],
      "calculate": {
        "Fc_Mechanics": {
          "type": "expression",
          "value": "m_Mechanics * ac_Mechanics"
        },
        "m_Mechanics": {
          "type": "expression",
          "value": "Fc_Mechanics / ac_Mechanics"
        },
        "ac_Mechanics": {
          "type": "expression",
          "value": "Fc_Mechanics / m_Mechanics"
        }
      }
    }
  ]
}
