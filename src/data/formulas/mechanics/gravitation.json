{
  "topic": "Mechanics",
  "subtopic": "Gravitation",
  "description": "Gravitational interactions near a planetary surface including weight and gravitational potential energy.",
  "formula_sub": [
    {
      "id": "grav-1",
      "name": "Weight Calculation",
      "formula": "W = mg",
      "variable": [
        "W_Mechanics",
        "m_Mechanics",
        "g_Mechanics"
      ],
      "calculate": {
        "W_Mechanics": {
          "type": "expression",
          "value": "m_Mechanics * g_Mechanics"
        },
        "m_Mechanics": {
          "type": "expression",
          "value": "W_Mechanics / g_Mechanics"
        },
        "g_Mechanics": {
          "type": "expression",
          "value": "W_Mechanics / m_Mechanics"
        }
      }
    },
    {
      "id": "grav-2",
      "name": "Gravitational Potential Energy",
      "formula": "E_{pg} = mgh",
      "variable": [
        "Epg_Mechanics",
        "m_Mechanics",
        "g_Mechanics",
        "h_Mechanics"
      ],
      "calculate": {
        "Epg_Mechanics": {
          "type": "expression",
          "value": "m_Mechanics * g_Mechanics * h_Mechanics"
        },
        "m_Mechanics": {
          "type": "expression",
          "value": "Epg_Mechanics / (g_Mechanics * h_Mechanics)"
        },
        "g_Mechanics": {
          "type": "expression",
          "value": "Epg_Mechanics / (m_Mechanics * h_Mechanics)"
        },
        "h_Mechanics": {
          "type": "expression",
          "value": "Epg_Mechanics / (m_Mechanics * g_Mechanics)"
        }
      }
    }
  ]
}
