{
  "topic": "Mechanics",
  "subtopic": "Momentum & Impulse",
  "description": "Momentum and impulse in one-dimensional motion, describing how motion changes when forces act over a time interval.",
  "formula_sub": [
    {
      "id": "mom-1",
      "name": "Momentum Definition",
      "formula": "p = mv",
      "variable": [
        "p_Mechanics",
        "m_Mechanics",
        "v_Mechanics"
      ],
      "calculate": {
        "p_Mechanics": {
          "type": "expression",
          "value": "m_Mechanics * v_Mechanics"
        },
        "m_Mechanics": {
          "type": "expression",
          "value": "p_Mechanics / v_Mechanics"
        },
        "v_Mechanics": {
          "type": "expression",
          "value": "p_Mechanics / m_Mechanics"
        }
      }
    },
    {
      "id": "mom-2",
      "name": "Change in Momentum (Velocity Form)",
      "formula": "\\Delta p = m(v - u)",
      "variable": [
        "deltap_Mechanics",
        "m_Mechanics",
        "v_Mechanics",
        "u_Mechanics"
      ],
      "calculate": {
        "deltap_Mechanics": {
          "type": "expression",
          "value": "m_Mechanics * (v_Mechanics - u_Mechanics)"
        },
        "m_Mechanics": {
          "type": "expression",
          "value": "deltap_Mechanics / (v_Mechanics - u_Mechanics)"
        },
        "v_Mechanics": {
          "type": "expression",
          "value": "(deltap_Mechanics / m_Mechanics) + u_Mechanics"
        },
        "u_Mechanics": {
          "type": "expression",
          "value": "v_Mechanics - (deltap_Mechanics / m_Mechanics)"
        }
      }
    },
    {
      "id": "mom-3",
      "name": "Impulse-Momentum Theorem",
      "formula": "J = m(v - u)",
      "variable": [
        "J_Mechanics",
        "m_Mechanics",
        "v_Mechanics",
        "u_Mechanics"
      ],
      "calculate": {
        "J_Mechanics": {
          "type": "expression",
          "value": "m_Mechanics * (v_Mechanics - u_Mechanics)"
        },
        "m_Mechanics": {
          "type": "expression",
          "value": "J_Mechanics / (v_Mechanics - u_Mechanics)"
        },
        "v_Mechanics": {
          "type": "expression",
          "value": "(J_Mechanics / m_Mechanics) + u_Mechanics"
        },
        "u_Mechanics": {
          "type": "expression",
          "value": "v_Mechanics - (J_Mechanics / m_Mechanics)"
        }
      }
    },
    {
      "id": "mom-4",
      "name": "Average Force during Impact",
      "formula": "F_{avg} = \\frac{J}{t - t_0}",
      "variable": [
        "Favg_Mechanics",
        "J_Mechanics",
        "t_Mechanics",
        "t0_Mechanics"
      ],
      "calculate": {
        "Favg_Mechanics": {
          "type": "expression",
          "value": "J_Mechanics / (t_Mechanics - t0_Mechanics)"
        },
        "J_Mechanics": {
          "type": "expression",
          "value": "Favg_Mechanics * (t_Mechanics - t0_Mechanics)"
        },
        "t_Mechanics": {
          "type": "expression",
          "value": "(J_Mechanics / Favg_Mechanics) + t0_Mechanics"
        },
        "t0_Mechanics": {
          "type": "expression",
          "value": "t_Mechanics - (J_Mechanics / Favg_Mechanics)"
        }
      }
    }
  ]
}
