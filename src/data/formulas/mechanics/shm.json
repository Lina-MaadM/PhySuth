{
  "topic": "Mechanics",
  "subtopic": "Simple Harmonic Motion",
  "description": "Basic SHM formulas for high school level: focus on position-based relationships and energy.",
  "formula_sub": [
    {
      "id": "shm-2",
      "name": "Acceleration at Position x",
      "formula": "a = -\\omega^2 x",
      "variable": [
        "a_Mechanics",
        "omega_Mechanics",
        "x_Mechanics"
      ],
      "calculate": {
        "a_Mechanics": {
          "type": "expression",
          "value": "-pow(omega_Mechanics, 2) * x_Mechanics"
        },
        "x_Mechanics": {
          "type": "expression",
          "value": "-a_Mechanics / pow(omega_Mechanics, 2)"
        },
        "omega_Mechanics": {
          "type": "expression",
          "value": "sqrt(abs(a_Mechanics / x_Mechanics))"
        }
      }
    },
    {
      "id": "shm-3",
      "name": "Maximum Velocity",
      "formula": "v_{max} = \\omega A",
      "variable": [
        "vmax_Mechanics",
        "omega_Mechanics",
        "A_Mechanics"
      ],
      "calculate": {
        "vmax_Mechanics": {
          "type": "expression",
          "value": "omega_Mechanics * A_Mechanics"
        },
        "omega_Mechanics": {
          "type": "expression",
          "value": "vmax_Mechanics / A_Mechanics"
        },
        "A_Mechanics": {
          "type": "expression",
          "value": "vmax_Mechanics / omega_Mechanics"
        }
      }
    },
    {
      "id": "shm-4",
      "name": "Maximum Acceleration",
      "formula": "a_{max} = \\omega^2 A",
      "variable": [
        "amax_Mechanics",
        "omega_Mechanics",
        "A_Mechanics"
      ],
      "calculate": {
        "amax_Mechanics": {
          "type": "expression",
          "value": "pow(omega_Mechanics, 2) * A_Mechanics"
        },
        "omega_Mechanics": {
          "type": "expression",
          "value": "sqrt(abs(amax_Mechanics / A_Mechanics))"
        },
        "A_Mechanics": {
          "type": "expression",
          "value": "amax_Mechanics / pow(omega_Mechanics, 2)"
        }
      }
    },
    {
      "id": "shm-5",
      "name": "Angular Frequency (Spring)",
      "formula": "\\omega = \\sqrt{k/m}",
      "variable": [
        "omega_Mechanics",
        "k_Mechanics",
        "m_Mechanics"
      ],
      "calculate": {
        "omega_Mechanics": {
          "type": "expression",
          "value": "sqrt(k_Mechanics / m_Mechanics)"
        },
        "k_Mechanics": {
          "type": "expression",
          "value": "pow(omega_Mechanics, 2) * m_Mechanics"
        },
        "m_Mechanics": {
          "type": "expression",
          "value": "k_Mechanics / pow(omega_Mechanics, 2)"
        }
      }
    },
    {
      "id": "shm-6",
      "name": "Total Energy",
      "formula": "E = \\frac{1}{2} k A^2",
      "variable": [
        "E_Mechanics",
        "k_Mechanics",
        "A_Mechanics"
      ],
      "calculate": {
        "E_Mechanics": {
          "type": "expression",
          "value": "0.5 * k_Mechanics * pow(A_Mechanics, 2)"
        },
        "k_Mechanics": {
          "type": "expression",
          "value": "2 * E_Mechanics / pow(A_Mechanics, 2)"
        },
        "A_Mechanics": {
          "type": "expression",
          "value": "sqrt(2 * E_Mechanics / k_Mechanics)"
        }
      }
    },
    {
      "id": "shm-7",
      "name": "Position-Time Equation",
      "formula": "x = A \\cos(\\omega t)",
      "variable": [
        "x_Mechanics",
        "A_Mechanics",
        "omega_Mechanics",
        "t_Mechanics"
      ],
      "calculate": {
        "x_Mechanics": {
          "type": "expression",
          "value": "A_Mechanics * cos(omega_Mechanics * t_Mechanics)"
        },
        "A_Mechanics": {
          "type": "expression",
          "value": "x_Mechanics / cos(omega_Mechanics * t_Mechanics)"
        },
        "omega_Mechanics": {
          "type": "expression",
          "value": "acos(x_Mechanics / A_Mechanics) / t_Mechanics"
        },
        "t_Mechanics": {
          "type": "expression",
          "value": "acos(x_Mechanics / A_Mechanics) / omega_Mechanics"
        }
      }
    }
  ]
}
