{
  "topic": "Mechanics",
  "subtopic": "Work, Energy, Power",
  "description": "The study of energy transfer through forces and the rate at which energy is transformed from one form to another in a system.",
  "formula_sub": [
    {
      "id": "wep-1",
      "name": "Work done by a constant force",
      "formula": "W = F d \\cos(\\theta)",
      "variable": [
        "W_Mechanics",
        "F_Mechanics",
        "d_Mechanics",
        "theta_Mechanics"
      ],
      "calculate": {
        "W_Mechanics": {
          "type": "expression",
          "value": "F_Mechanics * d_Mechanics * cosd(theta_Mechanics)"
        },
        "F_Mechanics": {
          "type": "expression",
          "value": "W_Mechanics / (d_Mechanics * cosd(theta_Mechanics))"
        },
        "d_Mechanics": {
          "type": "expression",
          "value": "W_Mechanics / (F_Mechanics * cosd(theta_Mechanics))"
        },
        "theta_Mechanics": {
          "type": "expression",
          "value": "acosd(W_Mechanics / (F_Mechanics * d_Mechanics))"
        }
      }
    },
    {
      "id": "wep-2",
      "name": "Kinetic Energy",
      "formula": "KE = \\frac{1}{2} m v^2",
      "variable": [
        "KE_Mechanics",
        "m_Mechanics",
        "v_Mechanics"
      ],
      "calculate": {
        "KE_Mechanics": {
          "type": "expression",
          "value": "0.5 * m_Mechanics * pow(v_Mechanics, 2)"
        },
        "m_Mechanics": {
          "type": "expression",
          "value": "(2 * KE_Mechanics) / pow(v_Mechanics, 2)"
        },
        "v_Mechanics": {
          "type": "expression",
          "value": "sqrt(2 * KE_Mechanics / m_Mechanics)"
        }
      }
    },
    {
      "id": "wep-3",
      "name": "Potential energy",
      "formula": "PE = m g h",
      "variable": [
        "PE_Mechanics",
        "m_Mechanics",
        "g_Mechanics",
        "h_Mechanics"
      ],
      "calculate": {
        "PE_Mechanics": {
          "type": "expression",
          "value": "m_Mechanics * g_Mechanics * h_Mechanics"
        },
        "m_Mechanics": {
          "type": "expression",
          "value": "PE_Mechanics / (g_Mechanics * h_Mechanics)"
        },
        "h_Mechanics": {
          "type": "expression",
          "value": "PE_Mechanics / (m_Mechanics * g_Mechanics)"
        },
        "g_Mechanics": {
          "type": "expression",
          "value": "PE_Mechanics / (m_Mechanics * h_Mechanics)"
        }
      }
    },
    {
      "id": "wep-4",
      "name": "Power (average)",
      "formula": "P = \\frac{W}{t}",
      "variable": [
        "P_Mechanics",
        "W_Mechanics",
        "t_Mechanics"
      ],
      "calculate": {
        "P_Mechanics": {
          "type": "expression",
          "value": "W_Mechanics / t_Mechanics"
        },
        "W_Mechanics": {
          "type": "expression",
          "value": "P_Mechanics * t_Mechanics"
        },
        "t_Mechanics": {
          "type": "expression",
          "value": "W_Mechanics / P_Mechanics"
        }
      }
    }
  ]
}
