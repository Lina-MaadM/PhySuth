  "formula_sub": [
    {
      
      "id": "wep-1",
      "name": "Work done by a constant force",
      "formula": "W = F d \\cos(\\theta)",
      "variable": ["W_Mechanics", "F_Mechanics", "d_Mechanics", "theta_Mechanics"],
      "calculate": {
        "W_Mechanics": { 
          "value": "F_Mechanics * d_Mechanics * cos(theta_Mechanics * PI / 180)" 
        },
        "F_Mechanics": { 
          "value": "W_Mechanics / (d_Mechanics * cos(theta_Mechanics * PI / 180))" 
        },
        "d_Mechanics": { 
          "value": "W_Mechanics / (F_Mechanics * cos(theta_Mechanics * PI / 180))" 
        },
        "theta_Mechanics": { 
          "value": "acos(W_Mechanics / (F_Mechanics * d_Mechanics)) * 180 / PI" 
        }

          }
    },
    {
      "id": "wep-2",
      "name": "Kinetic energy",
      "formula": "KE = \\frac{1}{2} m v^2",
      "variable": ["KE_Mechanics", "m_Mechanics", "v_Mechanics"],
      "calculate": {
        "KE_Mechanics": { "type": "expression", "value": "0.5 * m_Mechanics * v_Mechanics * v_Mechanics" },
        "m_Mechanics": { "type": "expression", "value": "2 * KE_Mechanics / (v_Mechanics * v_Mechanics)" },
        "v_Mechanics": { "type": "expression", "value": "sqrt(2 * KE_Mechanics / m_Mechanics)" }
      }
    },
    {
      "id": "wep-3",
      "name": "Potential energy",
      "formula": "PE = m g h",
      "variable": ["PE_Mechanics", "m_Mechanics", "g_Mechanics", "h_Mechanics"],
      "calculate": {
        "PE_Mechanics": { "type": "expression", "value": "m_Mechanics * g_Mechanics * h_Mechanics" }
      }
    },
    {
      "id": "wep-4",
      "name": "Power (average)",
      "formula": "P = \\frac{W}{t}",
      "variable": ["P_Mechanics", "W_Mechanics", "t_Mechanics"],
      "calculate": {
        "P_Mechanics": { "type": "expression", "value": "W_Mechanics / t_Mechanics" },
        "W_Mechanics": { "type": "expression", "value": "P_Mechanics * t_Mechanics" }
      }
    }
  ]
}