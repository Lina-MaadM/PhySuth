{
  "topic": "Optics",
  "subtopic": "Lenses and Mirrors",
  "description": "The study of image formation using the thin lens and mirror equations.",
  "formula_sub": [
    {
      "id": "opt-1",
      "name": "Lens/Mirror equation",
      "formula": "1/f = 1/s + 1/s'",
      "variable": [
        "f_Optics",
        "s_Optics",
        "sprime_Optics"
      ],
      "calculate": {
        "f_Optics": {
          "type": "expression",
          "value": "1 / ((1 / s_Optics) + (1 / sprime_Optics))"
        },
        "s_Optics": {
          "type": "expression",
          "value": "1 / ((1 / f_Optics) - (1 / sprime_Optics))"
        },
        "sprime_Optics": {
          "type": "expression",
          "value": "1 / ((1 / f_Optics) - (1 / s_Optics))"
        }
      }
    },
    {
      "id": "opt-2",
      "name": "Magnification",
      "formula": "m = -s' / s",
      "variable": [
        "m_Optics",
        "sprime_Optics",
        "s_Optics"
      ],
      "calculate": {
        "m_Optics": {
          "type": "expression",
          "value": "-sprime_Optics / s_Optics"
        },
        "sprime_Optics": {
          "type": "expression",
          "value": "-(m_Optics * s_Optics)"
        },
        "s_Optics": {
          "type": "expression",
          "value": "-sprime_Optics / m_Optics"
        }
      }
    }
  ]
}
