{
  "topic": "Thermodynamics",
  "subtopic": "Heat and Phase Change",
  "description": "The study of heat transfer during temperature change and phase change of a substance.",
  "formula_sub": [
    {
      "id": "phase-1",
      "name": "Specific heat (temperature change)",
      "formula": "Q = mc(T - T_0)",
      "variable": [
        "Q_Thermodynamics",
        "m_Thermodynamics",
        "c_Thermodynamics",
        "Tfinal_Thermodynamics",
        "Tinitial_Thermodynamics"
      ],
      "calculate": {
        "Q_Thermodynamics": {
          "type": "expression",
          "value": "m_Thermodynamics * c_Thermodynamics * (Tfinal_Thermodynamics - Tinitial_Thermodynamics)"
        },
        "Tfinal_Thermodynamics": {
          "type": "expression",
          "value": "(Q_Thermodynamics / (m_Thermodynamics * c_Thermodynamics)) + Tinitial_Thermodynamics"
        },
        "Tinitial_Thermodynamics": {
          "type": "expression",
          "value": "Tfinal_Thermodynamics - (Q_Thermodynamics / (m_Thermodynamics * c_Thermodynamics))"
        }
      }
    },
    {
      "id": "phase-2",
      "name": "Latent heat (phase change)",
      "formula": "Q = mL",
      "variable": [
        "Q_Thermodynamics",
        "m_Thermodynamics",
        "L_Thermodynamics"
      ],
      "calculate": {
        "Q_Thermodynamics": {
          "type": "expression",
          "value": "m_Thermodynamics * L_Thermodynamics"
        },
        "m_Thermodynamics": {
          "type": "expression",
          "value": "Q_Thermodynamics / L_Thermodynamics"
        },
        "L_Thermodynamics": {
          "type": "expression",
          "value": "Q_Thermodynamics / m_Thermodynamics"
        }
      }
    }
  ]
}
